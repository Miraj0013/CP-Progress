#include<bits/stdc++.h>
#define yes cout<<"YES"<<'\n'
#define no cout<<"NO"<<'\n'
#define pb push_back
#define ll long long
#define fast() ios_base::sync_with_stdio(0);cin.tie(0);cout.tie(0);
#define lcm(x, y) ((1LL * (x) * (y)) / __gcd((x), (y)))
 
using namespace std;
const int N=1000000009;
 
 
int main(){
  fast();
  int n;
  cin>>n;
  int arr[n];
  for (int i = 0; i < n; ++i)cin>>arr[i];
  ll sub[n];
  map<int,int>mem;
  int mn=0;
  for (int i = 0; i <n; ++i){
    sub[i]=i+1;
    if(mem[arr[i]])mn=max(mn,mem[arr[i]]);
    mem[arr[i]]=i+1;
    sub[i]-=mn;
  }
  ll ans=0;
  for (int i = 0; i < n; ++i)ans+=sub[i];
  cout<<ans;
}
