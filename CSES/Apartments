#include<bits/stdc++.h>
#define yes cout<<"YES"<<'\n'
#define no cout<<"NO"<<'\n'
#define pb push_back
#define ll long long
#define fast() ios_base::sync_with_stdio(0);cin.tie(0);cout.tie(0);
 
using namespace std;
 
int main(){fast();
  int n,m,k;
  cin>>n>>m>>k;
  int a[n],b[m];
  for(int i=0;i<n;i++){
    cin>>a[i];
  }
  for(int i=0;i<m;i++){
    cin>>b[i];
  }
  sort(a,a+n);
  sort(b,b+m);
  int i=0,j=0;
  int cnt=0;
  while(i<n and j<m){
    if(abs(a[i]-b[j])<=k){
      cnt++;
      i++;
      j++;
    }else if(a[i]<b[j]){
      i++;
    }else{
      j++;
    }
  }
 
  cout<<cnt;
}
