#include<bits/stdc++.h>
#define yes cout<<"YES"<<'\n'
#define no cout<<"NO"<<'\n'
#define pb push_back
#define ll long long
#define fast() ios_base::sync_with_stdio(0);cin.tie(0);cout.tie(0);
#define lcm(x, y) ((1LL * (x) * (y)) / __gcd((x), (y)))
 
using namespace std;
const int N=1000000007;
 
 
int main(){
  fast();
  int n;
  cin>>n;
  map<int,int>mp;
  for (int i = 0; i < n; ++i){
    int x;
    cin>>x;
    mp[x]++;
  }
  ll ans=1;
  for (auto i:mp)
  {
    i.second++;
    ans*=i.second;
    ans=ans%N;
  }
  ans--;
  cout<<ans;
}
