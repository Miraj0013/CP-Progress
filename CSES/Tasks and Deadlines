#include<bits/stdc++.h>
#define yes cout<<"YES"<<'\n'
#define no cout<<"NO"<<'\n'
#define pb push_back
#define ll long long
#define fast() ios_base::sync_with_stdio(0);cin.tie(0);cout.tie(0);
 
 
using namespace std;
const int N=1e9+7;
int main() {
    fast();
    int n;
    cin>>n;
    vector<pair<int, int>> a(n);
    for (int i = 0; i < n; ++i)
    {
        cin>>a[i].first>>a[i].second;
    }
    sort(a.begin(), a.end(), [](pair<int, int> &x, pair<int, int> &y) {
        return x.first < y.first;
    });
    ll ans=0;
    for (auto i:a){
        ans+=i.second;
        
    }
    ll s=0;
    for (auto i:a){
        s+=i.first;
        ans-=s;
    }
    cout<<ans;
}
