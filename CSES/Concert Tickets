#define pb push_back
#define ll long long
#define fast() ios_base::sync_with_stdio(0);cin.tie(0);cout.tie(0);
#define lcm(x, y) ((1LL * (x) * (y)) / __gcd((x), (y)))
 
using namespace std;
const int N=1000000009;
 
 
int main(){
  fast();
  int n,k;
  cin>>n>>k;
  multiset<int> arr;
  for (int i = 0; i < n; ++i)
  {
    int x;
    cin>>x;
    arr.insert(x);
  }
  
  while(k--){
    int x;
    cin>>x;
    auto ind =arr.upper_bound(x);
    if(ind==arr.begin())cout<<-1<<'\n';
    else{
      ind--;
      cout<<*(ind)<<'\n';
      arr.erase(ind);
    }
  }
}
 
